		<dependency>
			<groupId>be.vdab.monitoring</groupId>
			<artifactId>vdab-metrics-base-spring-boot-starter</artifactId>
		</dependency>
		<dependency>
			<groupId>be.vdab.actuator</groupId>
			<artifactId>vdab-raakvlakken-actuator-starter</artifactId>
			<version>${vdab-raakvlakken.version}</version>
