			<groupId>be.vdab</groupId>
			<artifactId>gebruikersbeheer-util</artifactId>
			<version>${gebruikersbeheer-util.version}</version>
		</dependency>
		<dependency>
			<groupId>be.vdab</groupId>
			<artifactId>token-utils</artifactId>
			<version>${token-utils.version}</version>
		</dependency>
		<dependency>
			<groupId>com.auth0</groupId>
			<artifactId>java-jwt</artifactId>
			<version>${java-jwt.version}</version>
		</dependency>
		<dependency>
			<groupId>be.vdab.iam</groupId>
			<artifactId>vdab-oidc-resourceserver-spring-boot-starter</artifactId>
		</dependency>
		<dependency>
			<groupId>be.vdab.artemis-config</groupId>
